# Google OAuth Client ID — required for Google Drive storage.
# See GCP_SETUP.md for setup instructions.
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Google OAuth Client Secret — required alongside the Client ID.
# Google's token endpoint requires the client_secret even for code+PKCE
# flows on Web application clients. PKCE remains the actual security
# control (an attacker who scrapes the secret from the bundle still needs
# the per-flow code_verifier to use it), so embedding the secret in the
# frontend bundle here is intentional. See GCP_SETUP.md.
VITE_GOOGLE_CLIENT_SECRET=your-client-secret-here

# Sentry DSN — optional, enables error monitoring.
VITE_SENTRY_DSN=

# Set to 1 to use in-browser mock implementations of Google auth and Drive.
# The mock runs fully locally (no Google round-trip) and persists to
# localStorage — useful for E2E testing and for demoing the app without a
# Google account. Leave unset in production.
VITE_USE_MOCK_DRIVE=
